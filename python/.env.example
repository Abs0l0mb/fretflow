# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cookie signing key (any long random string)
SECRET_KEY=

# App URL (no trailing slash)
APP_BASE_URL=http://localhost:8000

# Optional: comma-separated emails allowed to sign in (empty = allow all)
ALLOWED_EMAILS=

# Admin fallback account (used when DATABASE_URL is not set)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Supabase / Postgres
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Freemium limit
FREE_CONVERSIONS_PER_MONTH=10

# SMTP (for email verification)
# Gmail example: use an App Password (not your account password)
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=
SMTP_FROM=FretFlow <you@gmail.com>
